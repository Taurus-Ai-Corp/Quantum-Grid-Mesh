# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:***@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Hedera Network ───────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.000000
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HEDERA_AUDIT_TOPIC_ID=0.0.000000

# ─── Jurisdiction ─────────────────────────────────────────────────────────────
JURISDICTION=CA
NEXT_PUBLIC_JURISDICTION=CA

# ─── Platform Encryption ──────────────────────────────────────────────────────
PLATFORM_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ─── Authentication (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=***
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=***
STRIPE_WEBHOOK_SECRET=whsec_...xxxx

# ─── Stripe Debug Diag Route (TEMPORARY - delete after Stripe 500 is fixed) ───
# Required to call /api/guard/diag. Without this env var, the route returns 404.
# Pass to the route via ?secret=... query string OR Authorization: Bearer header.
# Generate a 32+ char random value: openssl rand -hex 32
# When Stripe checkout is fixed in production, DELETE apps/landing/src/app/api/guard/diag/route.ts and remove this env var.
DIAG_SECRET=replace-with-openssl-rand-hex-32

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx...xxxx

# ─── Cache (Upstash Redis) ────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxx...xxxx
