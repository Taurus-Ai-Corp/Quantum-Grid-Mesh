{
  "name": "q-grid-platform",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:brand": "bash scripts/check-brand.sh --all",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0"
  }
}
