  },
  "homepage": "https://guard.gridera.net",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {},
  "peerDependencies": {
    "@taurus/pqc-crypto": "workspace:*",
    "@taurus/hedera": "workspace:*"
  },
